# Copy this file to .env.local for local development with `vercel dev`.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# Required — your Google AI Studio key. Get one (free) at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Required — the shared RSVP code you give your guests. Case-insensitive on validation.
RSVP_CODE=

# Optional — the Gemini model to use. Defaults to gemini-2.5-flash.
# Other options: gemini-2.5-pro (much pricier), gemini-3-flash-preview (newer)
# GEMINI_MODEL=gemini-2.5-flash
